# ── Optimus Gol Radari - Coolify Environment Variables ─────────────
# Bu dosya Coolify'da deploy ederken kullanılır.
# PostgreSQL bağlantısı Coolify tarafından otomatik sağlanır.

# ── ZORUNLU: Veritabanı (Coolify otomatik doldurur) ──────────────
# Coolify PostgreSQL eklendiğinde DATABASE_URL otomatik gelir.
# Örnek: postgresql://user:password@host:5432/golradar_db
DATABASE_URL="postgresql://postgres:password@postgres:5432/golradar_db"

# ── Uygulama URL'si ──────────────────────────────────────────────
# Coolify domain'inizi buraya yazın (SSL için https ile)
NEXT_PUBLIC_APP_URL="https://golradar.sizin-domaininiz.com"

# ── İsteğe Bağlı: Diğer Ortam Değişkenleri ──────────────────────
# Aşağıdakiler opsiyoneldir, değiştirmezseniz varsayılan değerler kullanılır.

# Goal Radar Eşik Değerleri
# RADAR_THRESHOLD=65
# SIGNAL_5MIN_THRESHOLD=0.25
# POISSON_BLEND_WEIGHT=0.25
# MAX_PRESSURE_SNAPSHOTS=540

# API Timeout Süreleri (ms)
# NESINE_API_TIMEOUT=10000
# FOTMOB_API_TIMEOUT=10000
# GOALOO_API_TIMEOUT=15000
# SCOREMER_API_TIMEOUT=15000

# PWA Tema Rengi
# NEXT_PUBLIC_PWA_THEME_COLOR=#10b981

# Admin Panel için CORS İzinleri (virgülle ayırın)
# ALLOWED_ORIGINS="golradar.sizin-domaininiz.com,www.golradar.sizin-domaininiz.com"

# ML Trainer URL (varsa)
# ML_TRAINER_URL=http://ml-trainer:9100

# ── Feature Flags (opsiyonel, varsayılan değerler kullanılır) ──────
# Ensemble & Stacking
# STACKING_BLEND_ALPHA=0.5        # BMA+stacking blend (0=kapalı, 0.5=önerilen)
# ENABLE_ONLINE_ADJUSTMENTS=true  # Rolling 500-window weight rebalance (kapalı)

# Rating Sistemleri (DISABLE_* = true ile kapatılır, varsayılan AÇIK)
# DISABLE_PI_RATING=true          # Pi-Rating (Constantinou) kapat
# DISABLE_GLICKO2=true            # Glicko-2 kapat
# DISABLE_GAP_RATING=true         # Lite GAP Rating kapat (stub modda)

# Corrector (ZISM/Weibull)
# DISABLE_CORRECTOR=true          # ZISM Corrector kapat (varsayılan AÇIK)
# SKOR_KAPPA=-0.30                # Frank's Copula κ (önerilen: -0.30)
# ZISM_BETA=0.10                  # Zero-inflation β (tipik: 0.10)
# ZISM_MODE=frank                 # 'frank' veya 'zism'

# Sistem
# BACKTEST_PERSIST_JSON=true      # Backtest sonuçlarını JSON yaz
