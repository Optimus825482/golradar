# ── Database ─────────────────────────────────────────────────────
# Coolify PostgreSQL (Coolify otomatik doldurur)
DATABASE_URL="postgresql://postgres:PASSWORD@postgres:5432/golradar_db"

# ── Application ──────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Goal Radar Configuration ────────────────────────────────────
# Minimum score threshold for displaying a goal signal (0-100)
RADAR_THRESHOLD=65
# Minimum 5-minute goal probability to show a signal (0-1)
SIGNAL_5MIN_THRESHOLD=0.25
# Poisson blend weight (0-1)
POISSON_BLEND_WEIGHT=0.25
# Maximum pressure snapshots to retain per match
MAX_PRESSURE_SNAPSHOTS=540

# ── API Timeouts (milliseconds) ──────────────────────────────────
NESINE_API_TIMEOUT=10000
FOTMOB_API_TIMEOUT=10000
GOALOO_API_TIMEOUT=15000
SCOREMER_API_TIMEOUT=15000

# ── Socket.IO / Real-time ───────────────────────────────────────
# Mini-service port (Nesine WebSocket relay)
NESINE_LIVE_PORT=3003
# Docker internal hostname - frontend reaches this via nginx/Caddy
NEXT_PUBLIC_SOCKET_URL=http://golradar-nesine:3003
# CORS origin for socket server (frontend container hostname)
SOCKET_CORS_ORIGIN=http://golradar-web:3000

# ── Feature Flags (opsiyonel, varsayılan değerler kullanılır) ──────
# Ensemble & Stacking
# STACKING_BLEND_ALPHA=0.5        # BMA+stacking blend (0=kapalı, 0.5=önerilen)
# ENABLE_ONLINE_ADJUSTMENTS=true  # Rolling 500-window weight rebalance (kapalı)

# Rating Sistemleri (false ile kapatılır, varsayılan AÇIK)
# PI_RATING=false               # Pi-Rating (Constantinou) kapat
# GLICKO2=false                 # Glicko-2 kapat
# GAP_RATING=false              # Lite GAP Rating kapat

# Corrector (ZISM/Weibull)
# ZISM_CORRECTOR=false          # ZISM Corrector kapat (varsayılan AÇIK)
# SKOR_KAPPA=-0.30                # Frank's Copula κ (önerilen: -0.30)
# ZISM_BETA=0.10                  # Zero-inflation β (tipik: 0.10)
# ZISM_MODE=frank                 # 'frank' veya 'zism'

# Sistem
# BACKTEST_PERSIST_JSON=true      # Backtest sonuçlarını JSON yaz

# ── PWA ─────────────────────────────────────────────────────────
NEXT_PUBLIC_PWA_THEME_COLOR=#10b982
