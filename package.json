{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "bunx next dev -p 3028 2>&1",
    "build": "bunx next build && node -e \"const fs=require('fs');const cps=(s,d)=>fs.cpSync(s,d,{recursive:true,dereference:true});cps('.next/static','.next/standalone/.next/static');cps('public','.next/standalone/public');try{cps('node_modules/socket.io','.next/standalone/node_modules/socket.io');cps('node_modules/socket.io-client','.next/standalone/node_modules/socket.io-client');cps('node_modules/engine.io','.next/standalone/node_modules/engine.io');cps('node_modules/cors','.next/standalone/node_modules/cors')}catch(e){console.error('Copy deps failed:',e.message)}\"",
    "start": "NODE_ENV=production bun .next/standalone/server.js",
    "push-server": "bun src/lib/pushServer.ts",
    "lint": "eslint .",
    "test": "bun test",
    "test:ci": "bun test --reporter=github-actions 2>&1",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "echo '⚠️  DESTRUCTIVE — drops and recreates database. Run: prisma migrate reset'"
  },
  "dependencies": {
    "@prisma/client": "6.11.1",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "mermaid": "^11.4.0",
    "next": "^16.1.1",
    "pino": "^10.3.1",
    "playwright": "^1.61.0",
    "prisma": "6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.9.0",
    "server-only": "^0.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
