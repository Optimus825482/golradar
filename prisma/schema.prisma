// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Gol Radarı: Admin User ───────────────────────────────────────
model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  passwordHash        String    // pbkdf2 hex
  passwordSalt        String    // random hex salt
  mustChangePassword  Boolean   @default(true)
  sessionToken        String?   @unique // current login token
  sessionExpiresAt    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([username])
}

// ── Gol Radarı: Match Pressure Snapshots ─────────────────────────
// Stores periodic snapshots of match stats for momentum/trend analysis
model MatchSnapshot {
  id          String   @id @default(cuid())
  matchCode   Int      // Nesine match code
  minute      Int      // Match minute when snapshot was taken
  homePressure Int     // Calculated home pressure (0-100)
  awayPressure Int     // Calculated away pressure (0-100)
  homeGoals   Int      @default(0)
  awayGoals   Int      @default(0)
  statsJson   String   // JSON string of full MatchStats at this moment
  createdAt   DateTime @default(now())

  @@unique([matchCode, minute])
  @@index([matchCode, minute])
  @@index([matchCode, createdAt])
}

// ── Gol Radarı: Match Events ─────────────────────────────────────
// Goals, shots, cards, and other key events
model MatchEvent {
  id          String   @id @default(cuid())
  matchCode   Int
  eventType   String   // "goal", "shot_on_target", "red_card", "yellow_card", etc.
  side        String   // "home" or "away"
  minute      Int
  player      String?  // Player name if available
  xg          Float?   // xG value for shots
  createdAt   DateTime @default(now())

  @@index([matchCode, eventType])
  @@index([matchCode, minute])
}

// ── Gol Radarı: Prediction Log ───────────────────────────────────
// Records every prediction for backtesting and calibration
model PredictionLog {
  id               String   @id @default(cuid())
  matchCode        Int
  minute           Int
  rawScore         Int      // Raw Goal Radar score (0-100)
  homeScore        Int      // Home team threat score
  awayScore        Int      // Away team threat score
  calibratedP      Float    // Calibrated probability (0-1)
  side             String   // "home", "away", "both", "none"
  level            String   // "low", "medium", "high", "critical"
  factorsJson      String   // JSON array of active factors
  goalScored       Boolean? // null until match ends and we check
  minutesToGoal    Int?     // How many minutes after this prediction a goal was scored
  homeTeam         String
  awayTeam         String
  league           String
  homeElo          Int?     // Elo rating at prediction time
  awayElo          Int?     // Elo rating at prediction time
  poissonHomeP     Float?   // Dixon-Coles home goal probability
  poissonAwayP     Float?   // Dixon-Coles away goal probability
  // ML pipeline additions
  modelVariant     String   @default("champion") // "champion" | "shadow:<name>:<version>"
  featuresJson     String?  // Serialized 47-feature array at prediction time
  goalTimestamp    DateTime? // When the goal happened (for exact label alignment)
  createdAt        DateTime @default(now())

  @@index([matchCode, minute])
  @@index([calibratedP, goalScored])
  @@index([createdAt])
  @@index([modelVariant])
  @@index([matchCode, createdAt])
}

// ── Gol Radarı: Backtest Runs ────────────────────────────────────
// Records of automated backtest simulation runs
model BacktestRun {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  daysBack        Int
  maxMatches      Int
  signalThreshold Int      @default(60)
  totalMatches    Int
  signalsRecorded Int
  goalsDetected   Int
  accuracy        Float?
  avgTimeToGoal   Float?
  resultJson      String
  @@index([createdAt])
}

// ── Gol Radarı: Team Ratings ─────────────────────────────────────
// Elo ratings and derived attack/defense strength
model TeamRating {
  id              String   @id @default(cuid())
  teamName        String   @unique // Normalized team name
  teamNameTr      String?  // Turkish name for lookup
  elo             Int      @default(1500)
  attackStrength  Float    @default(1.0)  // α: relative to league avg
  defenseWeakness Float    @default(1.0)  // β: relative to league avg
  matchesPlayed   Int      @default(0)
  wins            Int      @default(0)
  draws           Int      @default(0)
  losses          Int      @default(0)
  goalsFor        Int      @default(0)
  goalsAgainst    Int      @default(0)
  xgFor           Float    @default(0)    // Cumulative xG scored
  xgAgainst       Float    @default(0)    // Cumulative xG conceded
  formJson        String   @default("[]") // JSON: last 10 results ["W","D","L",...]
  lastUpdated     DateTime @default(now())

  @@index([teamName])
  @@index([elo])
}

// ── Gol Radarı: Cross-Source Team Mapping ────────────────────────
// Maps team IDs across Nesine, Scoremer, FotMob, NetScores
model TeamMapping {
  id              String   @id @default(cuid())
  nesineCode      Int?     // Nesine match code (not team-specific, but league-level)
  nesineName      String?  // Team name from Nesine
  scoremerId      String?  // Scoremer match/team ID
  scoremerName    String?  // Team name from Scoremer
  fotmobId        Int?     // FotMob team ID
  fotmobName      String?  // Team name from FotMob
  netscoresId     String?  // NetScores team ID
  netscoresName   String?  // Team name from NetScores
  canonicalName   String   // Our canonical team name
  confidence      Float    @default(0) // Mapping confidence score (0-1)
  lastVerified    DateTime @default(now())

  @@unique([canonicalName])
  @@index([nesineName])
  @@index([scoremerId])
  @@index([fotmobId])
}

// ── Gol Radarı: Model Metrics ────────────────────────────────────
// Daily model performance metrics for tracking improvements
model ModelMetrics {
  id                String   @id @default(cuid())
  date              DateTime @unique // YYYY-MM-DD as Date
  brierScore        Float
  logLoss           Float
  accuracy          Float
  totalPredictions  Int
  totalGoals        Int
  avgCalibratedP    Float    // Average predicted probability
  goalAfterSignalP  Float    // % of signals followed by a goal
  avgMinutesToGoal  Float    // Average minutes from signal to goal
  calibrationError  Float    // Mean absolute calibration error
  poissonBrier      Float?   // Brier score for Poisson component
  eloBrier          Float?   // Brier score for Elo component
  // ML pipeline additions
  gbdtBrier         Float?   // Champion GBDT Brier
  xgbBrier          Float?   // XGBoost model Brier (when active)
  teamStrengthBrier Float?  // Kalman team-strength Brier
  inPlayBrier       Float?  // Live in-play 5-min model Brier
  shadowBrierDelta  Float?  // Signed delta: best shadow - champion. Negative = shadow wins.
  nShadowSamples    Int      @default(0)  // How many predictions contributed to shadowBrierDelta today
  createdAt         DateTime @default(now())

  @@index([date])
}

// ── Gol Radarı: Goal Signal Records ──────────────────────────────
// Persisted in PostgreSQL since the flat-file JSON migration.
// One row per signal above threshold. Goal verification + final scores
// are written in-place by the tracker. Active factor list stored as JSONB.
model Signal {
  id                  String   @id @default(cuid())
  matchCode           Int
  homeTeam            String
  awayTeam            String
  league              String
  matchTime           String
  date                String   // YYYY-MM-DD (local match date)

  signalMinute        Int
  signalSide          String   // "home" | "away"
  signalScore         Int      // Raw Goal Radar score 0-100 (first signal)
  calibratedP         Float    // Calibrated probability 0-1 (first signal)
  poissonP            Float    // Dixon-Coles Poisson probability (first signal)
  signalLevel         String   // "low" | "medium" | "high" | "critical"
  activeFactors       Json     // string[]

  // Updated every poll while signal is active (score keeps changing)
  lastScore           Int?     // Most recent score from latest poll
  lastCalibratedP     Float?   // Most recent calibrated probability
  lastPoissonP        Float?   // Most recent Poisson probability
  lastFactors         Json     @default("[]") // Most recent factors

  homeScore           Int      // Home threat score component
  awayScore           Int      // Away threat score component
  currentHomeGoals    Int
  currentAwayGoals    Int

  signalTimestamp     DateTime // First signal creation time
  lastSignalTimestamp DateTime? // Last poll update time

  // Goal verification (filled later by checkForGoals / expire)
  goalHappened        Boolean?
  goalMinute          Int?
  goalSide            String?  // "home" | "away"
  correctPrediction   Boolean?
  minutesAfterSignal  Int?
  goalTimestamp       DateTime?

  // Match result (filled by finalizeMatchSignals)
  finalHomeScore      Int?
  finalAwayScore      Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // One signal per match per side — upserted on every poll
  @@unique([matchCode, date, signalSide])
  @@index([date])
  @@index([matchCode])
  @@index([goalHappened])
  @@index([signalSide])
  @@index([calibratedP])
}

// ── Gol Radarı: FotMob Match Cache ───────────────────────────────
// Cached FotMob match details (weather, squad, H2H, form) for the
// goalRadar FotMob intelligence layer. TTL default 5 min; refresh
// is lazy on read. Single row per (fotmobId, matchDate) so the
// last successful fetch wins. JSONB payload keeps schema flexible
// as FotMob's response shape evolves.
model FotMobCache {
  id              String   @id @default(cuid())
  fotmobId        Int      // FotMob match ID
  matchDate       String   // YYYY-MM-DD — partitions by day, supports cleanup
  payload         Json     // Full FotMobMatchDetails as JSON
  fetchStatus     Int      @default(200) // HTTP status of the source fetch
  fetchError      String?  // Error message if fetch failed
  fetchedAt       DateTime @default(now()) // When we last hit FotMob
  expiresAt       DateTime // TTL boundary — soft expiry for read-time check
  hitCount        Int      @default(0) // How many reads served from this row
  lastHitAt       DateTime?

  @@unique([fotmobId, matchDate])
  @@index([fotmobId])
  @@index([matchDate])
  @@index([expiresAt])
}

// ── Gol Radarı: ML Training Dataset ──────────────────────────────
// Records each training-data export run. One row per (horizon, date)
// JSONL file. Consumed by the Python sidecar trainer to fit
// gradient-boosted models. SHA256 lets the trainer detect partial
// writes / corruption. Status transitions: ready → consumed → failed.
model TrainingDataset {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  horizonMin  Int      // 5 | 10 | 15
  rowCount    Int
  brier       Float?   // Brier on the export's own labels (sanity)
  logLoss     Float?
  path        String   // data/ml-training/5min-20260613.jsonl
  sha256      String
  status      String   @default("ready") // "ready" | "consumed" | "failed"
  errorMsg    String?
  // Bounding the export — old data may be dropped, recent data always kept.
  dataStart   DateTime? // Earliest createdAt included in this export
  dataEnd     DateTime? // Latest createdAt included

  @@index([createdAt])
  @@index([horizonMin, status])
  @@index([status, createdAt])
}

// ── Gol Radarı: Model Artifact Registry ──────────────────────────
// Versioned model files. Exactly one row per (name) is the champion
// (isChampion=true). Shadow models have isChampion=false and
// accumulate PredictionLog rows with modelVariant=shadow:<name>:<ver>
// for A/B comparison in the backtest pipeline.
model ModelArtifact {
  id            String   @id @default(cuid())
  name          String   // "gbdt" | "xgb" | "inplay" | "team-strength" | "xt-grid"
  version       String   // semver: "1.0.0"
  createdAt     DateTime @default(now())
  metricsJson   String   // {brier, logLoss, accuracy, calibrationError, n, trainRows, trainHorizon}
  artifactPath  String   // data/ml-models/<name>-v<version>.json
  sha256        String
  // Champion lifecycle
  promotedAt    DateTime?
  supersededBy  String?  // name of the row that replaced this as champion
  isChampion    Boolean  @default(false)
  // Audit
  notes         String?  // Free-form: "shadow-only 7d", "promoted via admin", etc.
  bytes         Int?     // Artifact file size for budget tracking

  @@unique([name, version])
  @@index([name, isChampion])
  @@index([name, createdAt])
  @@index([isChampion, name])
}

// ── Gol Radarı: Team History (Kalman backfill) ───────────────────
// Historical finished matches used to fit the per-team Kalman
// attack/defense state. Backfilled from Scoremer/Goaloo/NetScores
// HTML scrapers. One row per (date, homeTeam, awayTeam). The
// raw HTML response is NOT stored — only the parsed scores.
model TeamHistoryMatch {
  id          String   @id @default(cuid())
  matchDate   String   // YYYY-MM-DD
  homeTeam    String   // Normalized team name (lowercase, trimmed)
  awayTeam    String
  homeGoals   Int
  awayGoals   Int
  league      String?  // "Süper Lig", "Premier League", etc.
  source      String   // "scoremer" | "goaloo" | "netscores" | "manual"
  fetchedAt   DateTime @default(now())

  @@unique([matchDate, homeTeam, awayTeam])
  @@index([matchDate])
  @@index([homeTeam, matchDate])
  @@index([awayTeam, matchDate])
  @@index([source, fetchedAt])
}
